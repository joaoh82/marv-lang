mod std.result
import std.option (Option)

enum Result[T, E] {
    Ok(T),
    Err(E),
}

pure fn is_ok[T, E](res: &Result[T, E]) -> bool {
    match res {
        Result.Ok(_) => true,
        Result.Err(_) => false,
    }
}

pure fn ok[T, E](res: Result[T, E]) -> Option[T] {
    match res {
        Result.Ok(x) => Option.Some(x),
        Result.Err(_) => Option.None,
    }
}
