mod std.option

enum Option[T] {
    None,
    Some(T),
}

pure fn is_some[T](opt: &Option[T]) -> bool {
    match opt {
        Option.None => false,
        Option.Some(_) => true,
    }
}

pure fn unwrap_or[T](opt: Option[T], fallback: T) -> T {
    match opt {
        Option.None => fallback,
        Option.Some(x) => x,
    }
}
