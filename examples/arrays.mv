mod demo

pure fn dot3(a: [3]i64, b: [3]i64) -> i64 {
    (((a[0] * b[0]) + (a[1] * b[1])) + (a[2] * b[2]))
}

pure fn sum(xs: [4]i64) -> i64 {
    var total: i64 = 0
    var i: usize = 0
    while (i < len(xs)) {
        total = (total + xs[i])
        i = (i + 1)
    }
    total
}

pure fn main() -> i64 {
    let u: [3]i64 = [1, 2, 3]
    let v: [3]i64 = [4, 5, 6]
    var xs: [4]i64 = [0, 0, 0, 0]
    xs[0] = dot3(u, v)
    xs[3] = 10
    sum(xs)
}
