mod demo

enum Shape {
    Circle(i64),
    Rect(i64, i64),
}

pure fn area(s: Shape) -> i64 {
    match s {
        Shape.Circle(r) => (r * r),
        Shape.Rect(w, h) => (w * h),
    }
}

pure fn circle_area(r: i64) -> i64 {
    area(Shape.Circle(r))
}

pure fn rect_area(w: i64, h: i64) -> i64 {
    area(Shape.Rect(w, h))
}
